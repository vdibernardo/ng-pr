---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Nicole Greco | Consumer Brand PR & Communications Strategy",
  description = "Nicole Greco is a consumer brand PR strategist specializing in media relations, brand positioning, and communications strategy for food and lifestyle brands.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://www.ng-pr.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.ng-pr.com/" />
    <meta property="og:image" content="https://www.ng-pr.com/images/opengraph.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://www.ng-pr.com/images/opengraph.jpg" />
    <link rel="icon" href="/images/ngpr-favicon.ico" />
    <link rel="stylesheet" href="https://use.typekit.net/ffz1kqp.css" />
  </head>
  <body class="bg-indigo-50">
    <slot />
  </body>
</html>
