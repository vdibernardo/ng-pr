---
import testimonials from "../data/testimonials.json";
import TestimonialCard from "./TestimonialCard.astro";

const half = Math.ceil(testimonials.length / 2);
const columnA = testimonials.slice(0, half);
const columnB = testimonials.slice(half);
---

<div
  id="love_letters"
  class="flex flex-col items-center justify-center py-20 px-0 sm:px-14 gap-20"
>
  <h2 class="text-center text-orange-600 text-4xl/12 lg:text-5xl/15 xl:text-5xl/17">LOVE LETTERS</h2>

  <div class="flex flex-wrap items-start justify-center gap-8 relative mx-4 lg:mx-30 overflow-hidden lg:overflow-visible">
    <img src="/images/FISH.png" class="hidden lg:block absolute -top-55 -right-70 h-80" alt="" />
    <img src="/images/JAM.png" class="hidden lg:block absolute top-30 -left-78 h-105" alt="" />
    <img src="/images/CUP.png" class="hidden lg:block absolute bottom-55 -right-80 h-70" alt="" />
    <img src="/images/OLIVEOIL.png" class="hidden lg:block absolute -bottom-70 -left-60 h-120" alt="" />
    <div class="flex flex-col gap-8">
      {columnA.map((testimonial) => <TestimonialCard {...testimonial} />)}
    </div>
    <div class="flex flex-col gap-8">
      {columnB.map((testimonial) => <TestimonialCard {...testimonial} />)}
    </div>
  </div>
</div>
